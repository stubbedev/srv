{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/stubbedev/srv/master/schemas/metadata.schema.json",
  "$defs": {
    "Fallback": {
      "properties": {
        "url": {
          "type": "string",
          "description": "Remote URL to fall back to on 5xx (e.g. https://prod.example.com)."
        },
        "timeout": {
          "type": "string",
          "description": "Fallback request timeout (e.g. '2s')."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Limits": {
      "properties": {
        "max_body": {
          "type": "string",
          "description": "Maximum request body size (e.g. '2G' '128M' '500k')."
        },
        "read_timeout": {
          "type": "string",
          "description": "Read timeout (e.g. '300s' '5m')."
        },
        "send_timeout": {
          "type": "string",
          "description": "Send timeout (e.g. '300s')."
        },
        "connect_timeout": {
          "type": "string",
          "description": "Upstream connect timeout (e.g. '5s')."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Route": {
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable handle for the route used by 'srv route' CLI."
        },
        "path": {
          "type": "string",
          "description": "PathPrefix to match (e.g. /api)."
        },
        "path_regex": {
          "type": "string",
          "description": "Regex pattern to match (Traefik PathRegexp)."
        },
        "rewrite": {
          "type": "string",
          "description": "ReplacePathRegex replacement (e.g. /v1/$1)."
        },
        "upstream": {
          "$ref": "#/$defs/Upstream"
        },
        "preserve_host": {
          "type": "boolean",
          "description": "Whether to preserve the Host header (default true)."
        },
        "pass_range_headers": {
          "type": "boolean",
          "description": "Forward Range/If-Range headers for byte-range requests."
        },
        "priority": {
          "type": "integer",
          "description": "Traefik router priority override."
        },
        "limits": {
          "$ref": "#/$defs/Limits",
          "description": "Per-route limits override."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Upstream": {
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "localhost",
            "container",
            "url"
          ],
          "description": "Upstream target type."
        },
        "port": {
          "type": "integer",
          "description": "Port when kind=localhost or kind=container."
        },
        "container": {
          "type": "string",
          "description": "Container name when kind=container."
        },
        "url": {
          "type": "string",
          "description": "Full URL when kind=url (e.g. https://api.example.com)."
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "VolumeMount": {
      "properties": {
        "source": {
          "type": "string",
          "description": "Absolute host path."
        },
        "target": {
          "type": "string",
          "description": "Absolute path inside the container."
        },
        "read_only": {
          "type": "boolean",
          "description": "Mount the bind read-only."
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "metadata.yml schema version (1 = current)."
    },
    "type": {
      "type": "string",
      "enum": [
        "compose",
        "static",
        "dockerfile"
      ],
      "description": "Site runtime type."
    },
    "domains": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "All hostnames; the first entry is canonical."
    },
    "project_path": {
      "type": "string",
      "description": "Absolute path to the project on disk."
    },
    "service_name": {
      "type": "string",
      "description": "Container name used for Traefik routing."
    },
    "compose_service_name": {
      "type": "string",
      "description": "docker-compose service name (for compose commands)."
    },
    "profile": {
      "type": "string",
      "description": "docker-compose profile (if the service uses profiles)."
    },
    "port": {
      "type": "integer",
      "description": "Port the service listens on inside the container."
    },
    "is_local": {
      "type": "boolean",
      "description": "Whether to use a locally-issued (mkcert) SSL certificate."
    },
    "wildcard": {
      "type": "boolean",
      "description": "Match apex + one-level subdomains (*.example.com)."
    },
    "network_name": {
      "type": "string",
      "description": "Docker network the site joins."
    },
    "extra_networks": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Extra external Docker networks the site joins (for reaching user-managed containers like mysql01)."
    },
    "volumes": {
      "items": {
        "$ref": "#/$defs/VolumeMount"
      },
      "type": "array",
      "description": "Extra host bind-mounts attached to the site's container (e.g. ~/.nix-profile"
    },
    "listeners": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Extra Traefik entrypoints (e.g. 'internal' for plain HTTP on :88)."
    },
    "limits": {
      "$ref": "#/$defs/Limits",
      "description": "Request-body / timeout overrides."
    },
    "routes": {
      "items": {
        "$ref": "#/$defs/Route"
      },
      "type": "array",
      "description": "Extra Traefik routers (path-prefix / regex-rewrite splits)."
    },
    "upstream": {
      "$ref": "#/$defs/Upstream",
      "description": "Primary backend (proxy-type sites only)."
    },
    "fallback": {
      "$ref": "#/$defs/Fallback",
      "description": "Remote 5xx fallback target."
    },
    "spa": {
      "type": "boolean",
      "description": "Single-page-app mode (fall back to /index.html)."
    },
    "cache": {
      "type": "boolean",
      "description": "Emit aggressive caching headers for static assets."
    },
    "cors": {
      "type": "boolean",
      "description": "Emit permissive CORS headers."
    },
    "dockerfile_port": {
      "type": "integer",
      "description": "Port discovered from the Dockerfile EXPOSE directive."
    }
  },
  "additionalProperties": false,
  "type": "object",
  "title": "srv site metadata"
}
